---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import MarioSection from "../components/MarioSection.astro";
import MusiciansSection from "../components/MusiciansSection.astro";
import MusicSection from "../components/MusicSection.astro";
import VideosSection from "../components/VideosSection.astro";
import GallerySection from "../components/GallerySection.astro";
import PrestationsSection from "../components/PrestationsSection.astro";
import ContactSection from "../components/ContactSection.astro";
---

<Layout
	title="Riom — Trio acoustique pour mariages et événements en Île-de-France"
	description="Riom, trio acoustique folk, anime vos mariages, soirées d'entreprise et événements privés en Île-de-France, à Paris et dans le Val-d'Oise."
>
	<main>
		<Hero />
		<MarioSection />
		<MusiciansSection />
		<MusicSection />
		<VideosSection />
		<GallerySection />
		<PrestationsSection />
		<ContactSection />
	</main>
</Layout>
