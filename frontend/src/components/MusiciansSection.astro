---
import ScrollArrow from "./ScrollArrow.astro";

const musicians = [
	{ name: "Max", role: "Guitare", image: "/images/max.webp" },
	{ name: "Mario", role: "Chant & guitare", image: "/images/mario.webp" },
	{ name: "Clément", role: "Percussions", image: "/images/clement.webp" },
];
---

<section id="groupe" class="bg-riom-dark-900 pt-14 text-riom-cream sm:pt-24">
	<div class="reveal px-6 pb-10 pt-4 sm:px-10 sm:pb-16 lg:pb-24 lg:pt-6">
		<p class="text-xs font-semibold uppercase tracking-[0.3em] text-riom-amber">— Les musiciens —</p>

		<div class="mt-6 flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
			<h2 class="font-display text-4xl uppercase leading-[0.95] sm:text-5xl lg:text-6xl">
				Mario, Max &amp; Clément.
			</h2>
			<p class="max-w-xs text-sm text-riom-cream/70 sm:text-right">
				Une énergie commune, un lien direct avec le public — concert après concert.
			</p>
		</div>

		<div class="mt-12 grid gap-6 sm:grid-cols-3">
			{
				musicians.map((musician) => (
					<div class="img-skeleton group relative aspect-[3/4] overflow-hidden rounded-sm">
						<img
							src={musician.image}
							alt={`${musician.name} en concert — ${musician.role}`}
							class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
							loading="lazy"
						/>
						<div class="absolute inset-0 bg-gradient-to-t from-riom-dark-900 via-riom-dark-900/10 to-transparent" aria-hidden="true"></div>
						<div class="absolute inset-x-0 bottom-0 p-5">
							<p class="font-display text-2xl uppercase leading-none text-riom-cream">{musician.name}</p>
							<p class="mt-1 text-xs uppercase tracking-[0.2em] text-riom-amber">{musician.role}</p>
						</div>
					</div>
				))
			}
		</div>

		<ScrollArrow to="#ecouter" />
	</div>
</section>
