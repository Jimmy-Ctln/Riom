---

<header class="fixed inset-x-0 top-0 z-30 flex items-center justify-between bg-riom-dark-900/95 px-6 py-5 backdrop-blur-sm sm:px-10">
	<a
		href="#accueil"
		class="font-display text-2xl uppercase leading-none tracking-[0.08em] text-riom-cream transition hover:text-riom-amber sm:text-3xl"
	>
		RIOM
	</a>
	<button
		type="button"
		id="nav-toggle"
		class="group flex items-center gap-3 text-xs font-semibold uppercase tracking-[0.3em] text-riom-cream transition hover:text-riom-amber"
		aria-label="Ouvrir le menu"
		aria-controls="site-nav"
		aria-expanded="false"
	>
		Menu
		<span class="flex flex-col gap-1.5">
			<span class="block h-0.5 w-6 bg-riom-cream transition group-hover:bg-riom-amber"></span>
			<span class="block h-0.5 w-6 bg-riom-cream transition group-hover:w-4 group-hover:bg-riom-amber"></span>
		</span>
	</button>
</header>
