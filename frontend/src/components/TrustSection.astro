---
import ScrollArrow from "./ScrollArrow.astro";

const venues = [
	{
		name: "Pacific Rock",
		src: "/images/pacific-rock.webp",
		alt: "Riom en concert au Pacific Rock",
		href: "https://pacificrock.fr/",
	},
	{
		name: "Le Forum",
		src: "/images/le-forum.webp",
		alt: "Riom en concert au Forum",
		href: "https://leforum.cergypontoise.fr/",
	},
	{
		name: "Solidays",
		src: "/images/solidays.webp",
		alt: "Riom en concert à Solidays",
		href: "https://www.solidays.org/",
	},
];
---

<section id="confiance" class="bg-riom-dark-900 pt-24 text-riom-cream">
	<div class="reveal px-6 pb-24 pt-4 sm:px-10 lg:pb-32 lg:pt-6">
		<p class="text-sm font-semibold uppercase tracking-[0.3em] text-riom-amber">— Ils nous font confiance —</p>
		<h2 class="mt-6 font-display text-5xl uppercase leading-[0.95] sm:text-6xl lg:text-7xl">
			Des scènes qui nous ont invités.
		</h2>
		<p class="mt-8 max-w-xl text-lg leading-relaxed text-riom-cream/80 sm:text-xl">
			Festivals, salles et lieux culturels qui ont accueilli Riom sur leur scène.
		</p>

		<div class="mt-12 grid gap-6 sm:grid-cols-3">
			{
				venues.map((venue) => (
					<a
						href={venue.href}
						target="_blank"
						rel="noopener noreferrer"
						class="group overflow-hidden rounded-sm bg-riom-cream/5 transition hover:bg-riom-cream/10"
					>
						<div class="flex h-44 items-center justify-center bg-riom-cream/10 p-6 sm:h-52">
							<img
								src={venue.src}
								alt={venue.alt}
								class="h-full w-full object-contain transition duration-500 group-hover:scale-105"
								loading="lazy"
							/>
						</div>
						<div class="p-8">
							<span class="block h-px w-10 bg-riom-amber" aria-hidden="true" />
							<p class="mt-6 font-display text-2xl uppercase leading-none text-riom-cream underline-offset-4 group-hover:underline">
								{venue.name}
							</p>
						</div>
					</a>
				))
			}
		</div>

		<ScrollArrow to="#contact" />
	</div>
</section>
