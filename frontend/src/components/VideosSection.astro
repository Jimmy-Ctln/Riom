---
import VideoEmbed from "./VideoEmbed.astro";
---

<section id="videos" class="bg-riom-dark-900 pt-24 text-riom-cream">
	<div class="reveal px-6 pb-16 pt-4 sm:px-10 lg:pb-24 lg:pt-6">
		<h2 class="font-display text-5xl uppercase leading-[0.95] sm:text-6xl">En concert — les vidéos.</h2>

		<div class="mt-12 grid gap-6 lg:grid-cols-3">
			<div class="lg:col-span-2">
				<VideoEmbed id="pTMS6pvcqDA" eyebrow="Clip officiel" title="Au pied du mur" featured />
			</div>
			<div class="flex flex-col gap-6">
				<VideoEmbed id="YigSEqak8f0" eyebrow="Concert live" title="Riom en concert" />
				<VideoEmbed id="yyJFQcg-ItU" eyebrow="Concert live" title="Riom en concert" />
			</div>
		</div>

		<a
			href="https://www.youtube.com/@riom4132"
			target="_blank"
			rel="noopener noreferrer"
			class="mt-8 inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.2em] text-riom-amber transition hover:text-riom-cream"
		>
			Voir toutes les vidéos sur YouTube ↗
		</a>
	</div>
</section>
