---
import ScrollArrow from "./ScrollArrow.astro";

const highlights = [
	{
		title: "Formule sur mesure",
		description: "Guitare-voix en intimiste ou formation complète, selon votre lieu et votre budget.",
	},
	{
		title: "Concert d'1h30 environ",
		description: "Un set complet pensé pour les festivals et les théâtres.",
	},
	{
		title: "Disponible dans toute la France",
		description: "Riom se déplace partout en France pour vos événements et vos scènes.",
	},
];

const services = [
	{
		title: "Première partie d'artiste",
		description: "Riom assure la première partie de concerts, en festival comme en salle.",
	},
	{
		title: "Concert privé à domicile",
		description: "Anniversaires, soirées privées : un concert acoustique chez vous.",
	},
	{
		title: "Festivals & théâtres",
		description: "Un concert d'1h30 environ, pensé pour les grandes scènes comme pour la salle.",
	},
	{
		title: "Partout en France",
		description: "Basé en Île-de-France, Riom se déplace dans toute la France pour vos événements.",
	},
];
---

<section id="prestations" class="bg-riom-dark-800 pt-24 text-riom-cream">
	<div class="reveal grid gap-16 px-6 pb-24 pt-4 sm:px-10 lg:grid-cols-[1fr_1.15fr] lg:items-start lg:gap-20 lg:pb-32 lg:pt-6">
		<div>
			<p class="text-sm font-semibold uppercase tracking-[0.3em] text-riom-amber">— Jouer avec nous —</p>
			<h2 class="mt-6 font-display text-5xl uppercase leading-[0.95] sm:text-6xl lg:text-7xl">
				Inviter Riom, c'est simple.
			</h2>
			<p class="mt-8 max-w-xl text-lg leading-relaxed text-riom-cream/80 sm:text-xl">
				Première partie d'artiste, concert privé à domicile, ou set d'1h30 environ en festival et
				théâtre : Riom s'adapte à votre événement, en Île-de-France comme partout en France.
			</p>

			<ul class="mt-12 space-y-8">
				{
					highlights.map((item) => (
						<li class="flex gap-5">
							<span class="mt-2.5 h-2 w-2 shrink-0 rounded-full bg-riom-caramel" aria-hidden="true" />
							<div>
								<p class="text-base font-semibold uppercase tracking-[0.15em] text-riom-cream">{item.title}</p>
								<p class="mt-1.5 text-base text-riom-cream/70">{item.description}</p>
							</div>
						</li>
					))
				}
			</ul>

			<a
				href="#contact"
				class="mt-12 inline-flex items-center gap-2 rounded-sm bg-riom-caramel px-6 py-3 text-xs font-semibold uppercase tracking-[0.2em] text-riom-dark-900 transition hover:bg-riom-amber active:scale-95"
			>
				Faire venir Riom à mon événement
			</a>
		</div>

		<div class="grid gap-6 sm:grid-cols-2">
			{
				services.map((service) => (
					<div class="flex min-h-55 flex-col justify-center rounded-sm bg-riom-cream/5 p-10 transition hover:bg-riom-cream/10">
						<span class="block h-px w-10 bg-riom-amber" aria-hidden="true" />
						<p class="mt-6 font-display text-3xl uppercase leading-none text-riom-cream">{service.title}</p>
						<p class="mt-4 text-base text-riom-cream/70">{service.description}</p>
					</div>
				))
			}
		</div>
	</div>

	<ScrollArrow to="#confiance" />
</section>
