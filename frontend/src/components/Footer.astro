---
const year = new Date().getFullYear();
---

<footer class="border-t border-riom-cream/10 bg-riom-dark-900 text-riom-cream">
	<div class="px-6 py-12 sm:px-10 lg:py-16">
		<div class="flex flex-col items-start justify-between gap-6 border-b border-riom-cream/10 pb-10 sm:flex-row sm:items-center">
			<div>
				<p class="text-xs font-semibold uppercase tracking-[0.3em] text-riom-amber">Pour plus de rock</p>
				<p class="mt-2 font-display text-2xl uppercase leading-none sm:text-3xl">
					Découvrez Taxiphone, tribute Téléphone
				</p>
				<p class="mt-2 text-sm text-riom-cream/70">Le second groupe de Mario, pour les amateurs de rock français.</p>
			</div>
			<a
				href="https://taxiphonetributetelephone.fr/"
				target="_blank"
				rel="noopener noreferrer"
				class="shrink-0 rounded-sm border border-riom-cream/30 px-6 py-3 text-xs font-semibold uppercase tracking-[0.2em] transition hover:border-riom-cream active:scale-95"
			>
				Voir Taxiphone ↗
			</a>
		</div>

		<div class="mt-10 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
			<p class="font-display text-lg uppercase leading-none">Riom</p>
			<div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-6">
				<a
					href="https://www.facebook.com/Riom.officiel"
					target="_blank"
					rel="noopener noreferrer"
					class="flex items-center gap-2 text-sm text-riom-cream/70 transition hover:text-riom-cream"
				>
					<svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
						<path
							d="M22 12.06C22 6.51 17.52 2 12 2S2 6.51 2 12.06c0 5 3.66 9.15 8.44 9.94v-7.03H7.9v-2.91h2.54V9.84c0-2.51 1.49-3.89 3.78-3.89 1.1 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.88h2.78l-.44 2.91h-2.34V22c4.78-.79 8.44-4.94 8.44-9.94Z"
						></path>
					</svg>
					Facebook
				</a>
				<a
					href="https://www.youtube.com/@riom4132"
					target="_blank"
					rel="noopener noreferrer"
					class="flex items-center gap-2 text-sm text-riom-cream/70 transition hover:text-riom-cream"
				>
					<svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
						<path
							d="M21.6 7.2s-.21-1.5-.86-2.16c-.82-.87-1.74-.87-2.16-.92C15.6 4 12 4 12 4h-.01s-3.6 0-6.58.12c-.42.05-1.34.05-2.16.92-.65.66-.86 2.16-.86 2.16S2.18 9 2.18 10.8v1.68c0 1.8.21 3.6.21 3.6s.21 1.5.86 2.16c.82.87 1.9.84 2.38.93 1.73.17 7.37.22 7.37.22s3.6-.01 6.58-.13c.42-.06 1.34-.06 2.16-.93.65-.66.86-2.16.86-2.16s.21-1.8.21-3.6V10.8c0-1.8-.21-3.6-.21-3.6ZM9.96 14.98V8.9l5.4 3.04-5.4 3.04Z"
						></path>
					</svg>
					YouTube
				</a>
			</div>
		</div>

		<div class="mt-8 flex flex-col gap-2 border-t border-riom-cream/10 pt-6 text-sm sm:flex-row sm:items-center sm:justify-between">
			<p class="text-riom-cream/70">
				Photos par
				<a
					href="https://www.facebook.com/Blandine.Leclercq.Photographie?locale=fr_FR"
					target="_blank"
					rel="noopener noreferrer"
					class="font-semibold text-riom-amber underline transition hover:text-riom-cream"
				>
					Blandine Leclercq Photographie ↗
				</a>
			</p>
			<p class="text-xs text-riom-cream/40">© {year} Riom. Tous droits réservés.</p>
		</div>

		<p class="mt-4 flex items-center gap-2 text-xs text-riom-cream/40">
			Site web réalisé par
			<a
				href="https://www.linkedin.com/in/jimmycatalano/"
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex items-center gap-1.5 underline transition hover:text-riom-cream"
			>
				<svg viewBox="0 0 24 24" fill="currentColor" class="h-3.5 w-3.5" aria-hidden="true">
					<path
						d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.03-1.85-3.03-1.85 0-2.14 1.45-2.14 2.94v5.66H9.34V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.38-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12ZM7.12 20.45H3.56V9h3.56v11.45Z"
					></path>
				</svg>
				Jimmy Catalano
			</a>
		</p>
	</div>
</footer>
