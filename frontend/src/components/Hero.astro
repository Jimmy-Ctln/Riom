<section id="accueil" class="relative flex min-h-screen flex-col justify-end overflow-hidden bg-riom-dark-900">
	<img
		src="/images/riom.webp"
		alt="Riom en concert"
		class="absolute inset-0 h-full w-full object-cover"
		fetchpriority="high"
	/>
	<div class="absolute inset-0 bg-gradient-to-t from-riom-dark-900 via-riom-dark-900/60 to-riom-dark-900/20" aria-hidden="true"></div>

	<p class="relative z-10 mb-4 px-6 text-xs font-semibold uppercase tracking-[0.3em] text-riom-amber sm:mb-6 sm:px-10">
		Un artiste, des rencontres
	</p>

	<h1
		class="animate-hero-reveal relative z-10 -ml-1 px-6 font-display text-[28vw] leading-[0.8] tracking-tight text-riom-cream drop-shadow-[0_0_120px_rgba(224,152,40,0.45)] sm:px-10 sm:text-[24vw] lg:text-[20rem]"
	>
		RIOM
	</h1>

	<div class="relative z-10 mt-8 flex flex-col gap-8 px-6 pb-12 sm:flex-row sm:items-end sm:justify-between sm:px-10">
		<p class="max-w-sm font-serif text-xl italic text-riom-cream/90">
			Une voix, des cordes et des émotions.
		</p>

		<div class="flex flex-wrap gap-3">
			<a
				href="#ecouter"
				class="rounded-sm bg-riom-caramel px-6 py-3 text-xs font-semibold uppercase tracking-[0.2em] text-riom-dark-900 transition hover:bg-riom-amber active:scale-95"
			>
				+ Écouter
			</a>
			<a
				href="#contact"
				class="rounded-sm border border-riom-cream/60 px-6 py-3 text-xs font-semibold uppercase tracking-[0.2em] text-riom-cream transition hover:border-riom-cream active:scale-95"
			>
				Nous faire jouer
			</a>
		</div>
	</div>
</section>
